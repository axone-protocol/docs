    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^2.0.0-1",
    "rehype-katex": "7",
    "remark-math": "6",
    "sass": "^1.101.0",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
