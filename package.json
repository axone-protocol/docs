    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "sync:external-docs": "node .github/scripts/sync-external-docs.mjs",
    "sync:external-docs:dry-run": "node .github/scripts/sync-external-docs.mjs --dry-run",
    "lint": "stylelint '**/*.scss' && markdownlint README.md .github/**/*.md",
    "lint:fix": "stylelint '**/*.scss' --fix && markdownlint --fix README.md .github/**/*.md"
  },
  "dependencies": {
